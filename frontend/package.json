		"@testing-library/svelte": "^3.2.2",
		"@vitest/coverage-v8": "^2.1.8",
		"jsdom": "^25.0.1",
		"svelte-check": "^3.6.0",
		"vite": "^4.0.0",
		"vitest": "^2.1.8"
