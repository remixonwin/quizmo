# Django Settings
DEBUG=0
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ALLOWED_HOSTS=your-app.digitalocean.app,your-domain.com
DJANGO_SETTINGS_MODULE=windsurf_app.settings_digitalocean

# Database Settings
POSTGRES_DB=quiz_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Settings
REDIS_URL=redis://redis:6379/0

# DigitalOcean Spaces (S3-compatible storage)
DO_SPACES_ACCESS_KEY=your-spaces-access-key
DO_SPACES_SECRET_KEY=your-spaces-secret-key
DO_SPACES_BUCKET_NAME=your-bucket-name
DO_SPACES_REGION=nyc3

# Docker Settings
DOCKER_IMAGE_NAME=quiz-app
DOCKER_IMAGE_TAG=latest
WEB_REPLICAS=2
VOLUME_DRIVER=local

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# Monitoring Settings
SENTRY_DSN=your-sentry-dsn
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
